# Local development environment variables for Supabase Edge Functions.
# Copy this file to supabase/.env and replace placeholders with real values.
# Never commit real secrets.

OPENAI_API_KEY=your_openai_api_key_here
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=your_apple_client_secret_here
